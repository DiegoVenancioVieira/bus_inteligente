# Copie para .env (na raiz, ao lado do docker-compose.yml) e preencha.
# .env está no .gitignore — não será versionado.

# Directus desta VPS (projeto "Directus - BUS", SQLite) — já provisionado
DIRECTUS_URL=http://192.168.0.118:8057
DIRECTUS_TOKEN=coloque-o-token-de-servico-aqui

# URL pública por onde os passageiros abrem o app. Usada nos QR Codes.
#  - IP + HTTP (rápido, mas sem GPS do motorista):   http://SEU_IP:8060
#  - HTTPS via sslip.io no Coolify (recomendado):     https://bus-SEU-IP-COM-TRACOS.sslip.io
PUBLIC_URL=http://SEU_IP:8060

# Opcional: webhook para alertas operacionais (linha sem transmissão)
ALERT_WEBHOOK_URL=
